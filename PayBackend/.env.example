# Pay Plugin - Environment Variables Configuration
# Copy this file to .env and set your actual values
# WARNING: Never commit .env to version control!

# ============================================================================
# API Keys - REQUIRED for authentication
# ============================================================================
# Option 1: Single API key (simple)
# PAY_API_KEY=your-production-api-key-here

# Option 2: Multiple API keys (comma-separated)
PAY_API_KEYS=test-dev-key,performance-test-key,admin-test-key,prod-api-key-12345

# ============================================================================
# API Key Scopes (Optional - configure in config.json)
# ============================================================================
# Scopes are configured in config.json under "pay.api_key_scopes"
# Each key can have different scopes like:
# - read: Read-only access
# - write: Create/modify access
# - admin: Administrative access
# - order_query: Query payment orders
# - refund_query: Query refund status
# - refund: Create refunds
# - reconcile: Access reconciliation data

# Example scope configuration in config.json:
# "api_key_scopes": {
#   "test-dev-key": ["read", "write", "admin", "order_query", "refund_query", "refund"],
#   "performance-test-key": ["read", "write", "order_query", "refund_query"],
#   "admin-test-key": ["read", "write", "admin", "order_query", "refund_query", "refund", "reconcile"],
#   "prod-api-key-12345": ["read", "order_query", "refund_query"]
# }

# ============================================================================
# Database Configuration (Optional - overrides config.json)
# ============================================================================
# POSTGRES_USER=pay_user
# POSTGRES_PASSWORD=your-secure-password-here
# POSTGRES_DB=pay_production

# ============================================================================
# Redis Configuration (Optional - overrides config.json)
# ============================================================================
# REDIS_PASSWORD=your-redis-password-here

# ============================================================================
# WeChat Pay Configuration (Optional - overrides config.json)
# ============================================================================
# WECHAT_PAY_APP_ID=your-app-id
# WECHAT_PAY_MCH_ID=your-mch-id
# WECHAT_PAY_SERIAL_NO=your-serial-no
# WECHAT_PAY_API_V3_KEY=your-api-v3-key
