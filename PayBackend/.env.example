# Pay Backend Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# Application Configuration
# ===========================================
APP_THREADS=16
APP_ENABLE_SESSION=true
APP_SESSION_TIMEOUT=1200
APP_LOG_LEVEL=info

# ===========================================
# Server Configuration
# ===========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_ENABLE_HTTPS=false

# SSL/TLS Configuration (if HTTPS enabled)
SERVER_CERT_PATH=./certs/server.crt
SERVER_KEY_PATH=./certs/server.key
SERVER_CONF_PATH=./certs/openssl.cnf

# ===========================================
# WeChat Pay Configuration
# ===========================================
WECHAT_APPID=wx1234567890abcdef
WECHAT_MCHID=1234567890
WECHAT_API_V3_KEY=your_api_v3_key_here
WECHAT_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_KEY_PATH=./certs/apiclient_key.pem
WECHAT_SERIAL_NO=serial_number_here
WECHAT_NOTIFY_URL=https://yourdomain.com/api/callback
WECHAT_BASE_URL=https://api.mch.weixin.qq.com

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pay_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECTION_TIMEOUT=30
DB_MAX_CONNECTIONS=100

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_CONNECTION_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50

# ===========================================
# Idempotency Configuration
# ===========================================
IDEMPOTENCY_TTL=604800
IDEMPOTENCY_USE_REDIS=true

# ===========================================
# Monitoring Configuration
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false

# ===========================================
# Security Configuration
# ===========================================
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ===========================================
# Feature Flags
# ===========================================
ENABLE_REFUND=true
ENABLE_RECONCILIATION=true
ENABLE_CALLBACK=true
RECONCILIATION_CRON="0 2 * * *"
